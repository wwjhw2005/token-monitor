{
  "name": "token-monitor",
  "productName": "Token Monitor",
  "version": "0.16.0",
  "description": "Live token & cost widget for Claude Code, Codex & Hermes — local-first, optional multi-device sync.",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "hub": "node src/hub/server.js",
    "agent": "node src/agent/agent.js",
    "agent:once": "node src/agent/agent.js --once",
    "widget": "electron .",
    "dev": "electron .",
    "test": "node --test \"tests/**/*.test.js\"",
    "icons": "node scripts/build-icons.js",
    "prepack": "npm run icons",
    "predist:mac": "npm run icons",
    "predist:win": "npm run icons",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac --arm64",
    "dist:win": "electron-builder --win --x64",
    "lint": "eslint .",
    "verify": "npm run lint && npm test"
  },
  "build": {
    "appId": "com.javis.tokenmonitor",
    "productName": "Token Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/electron/**/*",
      "src/shared/**/*",
      "src/hub/**/*",
      "assets/icon.png",
      "assets/icons/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@tokscale/**/*",
      "node_modules/tokscale/**/*",
      "node_modules/koffi/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "publish": null
  },
  "keywords": [
    "tokscale",
    "claude-code",
    "codex",
    "hermes",
    "token-monitor",
    "token-usage",
    "cost-tracking",
    "llm",
    "ai-tools",
    "electron",
    "desktop-widget",
    "local-first",
    "self-hosted"
  ],
  "author": "Javis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Javis603/token-monitor.git"
  },
  "homepage": "https://github.com/Javis603/token-monitor#readme",
  "bugs": {
    "url": "https://github.com/Javis603/token-monitor/issues"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "koffi": "^3.0.2",
    "semver": "^7.8.1",
    "tar": "^7.5.15",
    "tokscale": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "electron": "42.2.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
