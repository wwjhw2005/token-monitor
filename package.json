{
  "name": "token-monitor",
  "productName": "Token Monitor",
  "version": "0.35.0",
  "description": "Live token & cost widget for Claude Code, Codex & Hermes — local-first, optional multi-device sync.",
  "main": "src/electron/main.js",
  "scripts": {
    "start": "electron .",
    "hub": "node src/hub/server.js",
    "agent": "node src/agent/agent.js",
    "agent:once": "node src/agent/agent.js --once",
    "widget": "electron .",
    "dev": "electron .",
    "test": "node --test \"tests/**/*.test.js\"",
    "sync:worker": "node scripts/sync-worker-shared.js",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac --arm64 --publish never",
    "dist:mac:x64": "electron-builder --mac --x64 --publish never",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:win:dir": "electron-builder --win dir --x64 --publish never",
    "dist:win:prepackaged": "electron-builder --prepackaged dist/win-unpacked --win nsis portable --x64 --publish never",
    "dist:linux": "electron-builder --linux --x64 --publish never",
    "verify:release-artifact-names": "node scripts/verify-updater-artifact-names.js dist",
    "lint": "eslint .",
    "verify": "npm run lint && npm test"
  },
  "build": {
    "appId": "com.javis.tokenmonitor",
    "productName": "Token Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/electron/**/*",
      "src/shared/**/*",
      "src/hub/**/*",
      "assets/icon.png",
      "assets/icons/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@tokscale/**/*",
      "node_modules/tokscale/**/*",
      "node_modules/koffi/**/*"
    ],
    "mac": {
      "artifactName": "Token-Monitor-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "forceCodeSigning": false,
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon-win.png",
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "artifactName": "Token-Monitor-${version}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "synopsis": "Live token & cost widget for AI coding tools",
      "description": "Real-time token, cost, and AI limits widget with multi-device sync for Claude Code, Codex, OpenCode and more."
    },
    "nsis": {
      "artifactName": "Token-Monitor-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Token-Monitor-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wwjhw2005",
        "repo": "token-monitor"
      }
    ]
  },
  "keywords": [
    "tokscale",
    "claude-code",
    "codex",
    "hermes",
    "token-monitor",
    "token-usage",
    "cost-tracking",
    "llm",
    "ai-tools",
    "electron",
    "desktop-widget",
    "local-first",
    "self-hosted"
  ],
  "author": "Javis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wwjhw2005/token-monitor.git"
  },
  "homepage": "https://github.com/wwjhw2005/token-monitor#readme",
  "bugs": {
    "url": "https://github.com/wwjhw2005/token-monitor/issues"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "chokidar": "^4.0.3",
    "dotenv": "^17.4.2",
    "electron-updater": "6.8.9",
    "koffi": "^3.1.2",
    "semver": "^7.8.5",
    "tar": "^7.5.21",
    "tokscale": "^4.6.1",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
