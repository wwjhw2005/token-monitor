# Token Monitor — environment configuration.
# Copy to .env (gitignored) and fill in. Only needed for the hub and the
# headless agent; the widget can also read these as first-run defaults
# before its GUI settings take over.

# Hub URL — required for the agent and for any widget in sync mode.
# Leave empty for single-device local mode (widget reads files directly, no hub).
# Example: https://token-monitor-hub.<your-subdomain>.workers.dev  or  http://192.168.1.10:17321
TOKEN_MONITOR_HUB_URL=

# Shared secret — must match on the hub, agent, and any widget that syncs.
# Leave empty to run the hub without authentication (not recommended).
# Generate a random one with: openssl rand -hex 32
TOKEN_MONITOR_SECRET=

# Device identifier. Optional — defaults to the machine hostname.
TOKEN_MONITOR_DEVICE_ID=

# Widget sync upload cadence. Optional — defaults to live uploads.
# Accepted values: 0 (live), 600000 (10 min), 1200000 (20 min), 1800000 (30 min).
# Used as a first-run default; a saved GUI setting takes precedence.
TOKEN_MONITOR_SYNC_UPLOAD_INTERVAL_MS=0

# Comma-separated client list. Optional — leave unset to track all supported tools.
# Set to empty to disable tracking.
# Example: claude,codex,hermes,opencode,openclaw,cursor,antigravity,cline,kimi,qwen,grok,copilot,pi,zed,kilocode,micode,zcode,kiro,codebuddy,workbuddy,proma
TOKEN_MONITOR_CLIENTS=claude,codex,hermes,opencode,openclaw,cursor,antigravity,cline,kimi,qwen,grok,copilot,pi,zed,kilocode,micode,zcode,kiro,codebuddy,workbuddy,proma

# Projects — collect local workspace metadata for the Projects view.
# Optional — defaults to disabled. Set to 1 to enable.
TOKEN_MONITOR_PROJECTS_ENABLED=

# Usage Trends — collect historical trend data for the Trends dashboard.
# Optional — defaults to enabled. Set to 0 to disable.
TOKEN_MONITOR_HISTORY_ENABLED=

# AI Tool Limits — detect supported provider session, weekly, billing, and credit windows.
# Optional — defaults to enabled. Set to 0 to disable entirely (skips probing the local CLIs).
TOKEN_MONITOR_LIMITS_ENABLED=

# Providers to probe. Optional — defaults to all supported (claude, codex, cursor, antigravity, opencode, deepseek, minimax, mimo, grok, copilot, kiro, zai, zaiteam, volcengine, qoder, kimi, ollama, wecode).
# Example: claude,codex   (probe only Claude Code and Codex)
TOKEN_MONITOR_LIMIT_PROVIDERS=

# Grok bearer token. Optional — Token Monitor normally auto-detects Grok via
# ~/.grok/auth.json after `grok login`; use this for the headless agent,
# hubless scripts, or environment-managed secrets.
GROK_BEARER_TOKEN=

# Optional proxy for Grok web billing. Lowercase variants are also supported
# and take precedence; NO_PROXY/no_proxy bypasses matching hosts.
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=
NO_PROXY=

# DeepSeek balance API key. Optional — the widget has a GUI account setting;
# use this for the headless agent, hubless scripts, or environment-managed secrets.
DEEPSEEK_API_KEY=

# Minimax Token Plan API key. Optional — the widget has a GUI account setting;
# use this for the headless agent, hubless scripts, or environment-managed secrets.
# This is not the regular pay-as-you-go API key — the two are not interchangeable.
MINIMAX_CODING_API_KEY=

# GitHub Copilot OAuth token. Optional — the widget can sign in with GitHub;
# use this for the headless agent, hubless scripts, or environment-managed secrets.
# GITHUB_COPILOT_TOKEN is also accepted for compatibility.
COPILOT_API_TOKEN=

# GLM Coding Plan API key from Z.ai Open Platform. Optional — the widget has a GUI account setting.
# Z_AI_API_KEY, GLM_API_KEY, and ZHIPU_API_KEY are also accepted for compatibility.
# TOKEN_MONITOR_ZAI_API_REGION may be "global" (api.z.ai) or "bigmodel-cn" (open.bigmodel.cn).
ZAI_API_KEY=
TOKEN_MONITOR_ZAI_API_REGION=global

# GLM Team Plan (BigModel CN only). ZAI_TEAM_API_KEY or BIGMODEL_TEAM_API_KEY
# supplies the team API key separately from the personal GLM provider. The
# Organization ID and Project ID are found in the bigmodel.cn page localStorage
# (Bigmodel-Organization / Bigmodel-Project). Optional — the widget has a GUI account setting.
ZAI_TEAM_API_KEY=
ZAI_TEAM_ORGANIZATION_ID=
ZAI_TEAM_PROJECT_ID=

# Volcengine Ark credentials. Optional — the widget has a GUI account setting.
# Paste an Ark API key (ark-...), or an access key ID (AKLT...) plus secret.
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
VOLCENGINE_REGION=cn-beijing

# Qoder dashboard cookie for big-model credits. Optional — the widget has a GUI account setting.
# TOKEN_MONITOR_QODER_SITE may be "global" or "cn".
QODER_COOKIE=
TOKEN_MONITOR_QODER_SITE=global

# Ollama Cloud Cookie request header for session/weekly usage. Optional — the widget has a GUI account setting.
OLLAMA_COOKIE=

# Kimi Code API key. Optional — the widget has a GUI account setting.
KIMI_CODE_API_KEY=

# WeCode (Weibo internal) quota username(s). Optional — probes the internal
# copilot.weibo.com quota API; accepts a comma-separated list to track several
# accounts. WECODE_PROXY routes the request through an HTTP proxy (e.g.
# http://localhost:9090) when the host is not directly reachable from this machine.
WECODE_USER=
WECODE_PROXY=
